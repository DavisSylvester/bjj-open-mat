# Monorepo root ignores (Flutter app keeps its own apps/mobile/.gitignore)

# Node / Bun
node_modules/
.turbo/
dist/
*.tsbuildinfo
bun.lockb.bak

# Env
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
*.log

# Playwright (audit artifacts)
.playwright-mcp/

# Debug/audit screenshots dropped in the repo root
/*.png

# AI working artifacts (screenshots, ui dumps)
.docs/

# Android keystore password (never commit)
.android-password
.android-keystore.b64

# Google Play service account (never commit)
.google-service-account.json

# Website (Angular landing app)
website/node_modules/
website/dist/
website/.angular/
website/test-results/
website/reference/*.png
website/*.png
